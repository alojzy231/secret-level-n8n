{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/worktree-setup.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/worktree-teardown.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
