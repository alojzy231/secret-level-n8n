{
  "name": "Pancake Recipe - Webhook + Gemini 2.5 Flash",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "pancake-recipe",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "b1c2d3e4-0001-0001-0001-000000000001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "pancake-recipe"
